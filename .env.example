# At least one LLM provider key is required
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: local models via OpenWebUI (OPENWEBUI_API_URL required if key is set)
OPENWEBUI_API_KEY=
OPENWEBUI_API_URL=

# Optional: proxy URL for OpenAI requests (defaults to https://api.openai.com/)
# OPENAI_PROXY_URL=

# Optional: Redis for response caching (falls back to in-memory if unavailable)
# REDIS_HOST=localhost
# REDIS_PORT=6379
