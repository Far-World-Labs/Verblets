{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "@context": {
      "type": "string",
      "pattern": "^https://schema.org$"
    },
    "@type": {
      "type": "string",
      "enum": ["Place", "City"]
    },
    "name": {
      "type": "string"
    },
    "alternateName": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "description": {
      "type": "string"
    },
    "population": {
      "oneOf": [
        { "type": "integer", "minimum": 0 },
        {
          "type": "object",
          "properties": {
            "@type": {
              "type": "string",
              "enum": ["QuantitativeValue"]
            },
            "value": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      ]
    },
    "area": {
      "oneOf": [
        { "type": "number", "minimum": 0 },
        {
          "type": "object",
          "properties": {
            "@type": {
              "type": "string",
              "enum": ["QuantitativeValue"]
            },
            "value": {
              "type": "number",
              "minimum": 0
            },
            "unitCode": {
              "type": "string"
            }
          }
        }
      ]
    },
    "elevation": {
      "oneOf": [
        { "type": "number" },
        {
          "type": "object",
          "properties": {
            "@type": {
              "type": "string",
              "enum": ["QuantitativeValue"]
            },
            "value": {
              "type": "number"
            },
            "unitCode": {
              "type": "string"
            }
          }
        }
      ]
    },
    "address": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string",
          "enum": ["PostalAddress"]
        },
        "streetAddress": {
          "type": "string"
        },
        "addressLocality": {
          "type": "string"
        },
        "addressRegion": {
          "type": "string"
        },
        "postalCode": {
          "type": "string"
        },
        "addressCountry": {
          "type": "string"
        }
      }
    },
    "geo": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string",
          "enum": ["GeoCoordinates"]
        },
        "latitude": {
          "type": "number"
        },
        "longitude": {
          "type": "number"
        }
      }
    },
    "areaServed": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "properties": {
            "@type": {
              "type": "string",
              "enum": ["AdministrativeArea"]
            },
            "name": {
              "type": "string"
            }
          }
        }
      ]
    },
    "additionalType": {
      "type": "string"
    },
    "sameAs": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "containedInPlace": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "containsPlace": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "@type": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": ["@type", "name"]
}
