{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "claims": {
      "type": "array",
      "description": "Primary assertions or propositions identified in the text",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for cross-referencing"
          },
          "statement": {
            "type": "string",
            "description": "The claim expressed as a clear proposition"
          },
          "type": {
            "type": "string",
            "enum": ["factual", "evaluative", "causal", "prescriptive", "definitional"],
            "description": "Classification of the claim"
          },
          "confidence": {
            "type": "string",
            "enum": ["strong", "moderate", "weak"],
            "description": "How strongly the text supports this claim"
          }
        },
        "required": ["id", "statement", "type", "confidence"],
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "description": "Supporting data, examples, or reasoning backing claims",
      "items": {
        "type": "object",
        "properties": {
          "claimId": {
            "type": "string",
            "description": "ID of the claim this evidence supports"
          },
          "content": {
            "type": "string",
            "description": "The evidence statement or data point"
          },
          "type": {
            "type": "string",
            "enum": ["empirical", "logical", "testimonial", "analogical", "statistical"],
            "description": "Classification of the evidence"
          },
          "strength": {
            "type": "string",
            "enum": ["strong", "moderate", "weak"],
            "description": "How well this evidence supports the claim"
          }
        },
        "required": ["claimId", "content", "type", "strength"],
        "additionalProperties": false
      }
    },
    "counterarguments": {
      "type": "array",
      "description": "Objections, rebuttals, or alternative positions",
      "items": {
        "type": "object",
        "properties": {
          "targetClaimId": {
            "type": "string",
            "description": "ID of the claim being challenged"
          },
          "statement": {
            "type": "string",
            "description": "The counterargument expressed clearly"
          },
          "type": {
            "type": "string",
            "enum": ["rebuttal", "undercutter", "alternative"],
            "description": "How this counterargument challenges the claim"
          },
          "strength": {
            "type": "string",
            "enum": ["strong", "moderate", "weak"],
            "description": "How effectively this counters the target claim"
          }
        },
        "required": ["targetClaimId", "statement", "type", "strength"],
        "additionalProperties": false
      }
    }
  },
  "required": ["claims", "evidence", "counterarguments"],
  "additionalProperties": false
}
